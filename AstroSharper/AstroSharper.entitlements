<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
    <key>com.apple.developer.ubiquity-kvstore-identifier</key>
    <string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
    <!-- Required for outbound HTTP from inside the sandbox. Without
         this the sandbox blocks /private/var/run/mDNSResponder so even
         DNS resolution fails (URLSession returns -1003
         "ServiceNotRunning"). Needed by TelemetryClient + CommunityShare
         POSTs to the shared Supabase project, and by any future feature
         that talks to a remote endpoint (App Store review URL opens
         externally, doesn't need this; in-app fetches do). -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
